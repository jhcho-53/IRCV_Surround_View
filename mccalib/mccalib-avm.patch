diff --git a/CMakeLists.txt b/CMakeLists.txt
index 9b19dc3..cad4532 100755
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -14,9 +14,15 @@ include_directories( ${OpenCV_INCLUDE_DIRS} )
 find_package(Ceres REQUIRED)
 
 # boost related setup
-set(Boost_USE_STATIC_LIBS ON)
+# Default to static libs (as in the Docker image); allow override for
+# environments that only ship shared Boost (e.g. conda-forge): -DBoost_USE_STATIC_LIBS=OFF
+if(NOT DEFINED Boost_USE_STATIC_LIBS)
+  set(Boost_USE_STATIC_LIBS ON)
+endif()
 set(Boost_USE_MULTITHREADED ON)
-find_package(Boost COMPONENTS log system REQUIRED)
+# Boost.System is header-only since Boost 1.69 and has no standalone CMake
+# component in Boost >= 1.90 (conda-forge); it is pulled in transitively by log.
+find_package(Boost COMPONENTS log REQUIRED)
 message(STATUS "Boost version: ${Boost_VERSION}")
 
 IF(SSSE3_FOUND)
